// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  HOTEL_MANAGER
  FLIGHT_MANAGER
  ADMIN
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum FlightStatus {
  SCHEDULED
  BOARDING
  DEPARTED
  ARRIVED
  CANCELLED
  DELAYED
}

enum RoomType {
  SINGLE
  DOUBLE
  SUITE
  FAMILY
  DELUXE
}

// ========================
// USER
// ========================
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(CLIENT)
  isBlocked    Boolean  @default(false)
  firstName    String
  lastName     String
  phone        String?
  avatarUrl    String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  flightReservations FlightReservation[]
  hotelReservations  HotelReservation[]
  reviews            Review[]
  notifications      Notification[]
  managedHotels      Hotel[]             @relation("HotelManager")
  managedAirlines    AirlineCompany[]    @relation("AirlineManager")
  passwordResets     PasswordReset[]

  @@map("users")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// ========================
// AIRLINE & FLIGHT
// ========================
model AirlineCompany {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String?  @db.Text
  country   String
  iataCode  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  flights  Flight[]
  managers User[]   @relation("AirlineManager")

  @@map("airline_companies")
}

model Flight {
  id             String       @id @default(cuid())
  flightNumber   String       @unique
  origin         String
  destination    String
  departureTime  DateTime
  arrivalTime    DateTime
  price          Decimal      @db.Decimal(10, 2)
  totalSeats     Int
  availableSeats Int
  status         FlightStatus @default(SCHEDULED)
  airlineId      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  airline      AirlineCompany      @relation(fields: [airlineId], references: [id])
  reservations FlightReservation[]
  reviews      Review[]

  @@map("flights")
}

// ========================
// HOTEL & ROOM
// ========================
model Hotel {
  id          String   @id @default(cuid())
  name        String
  city        String
  address     String
  stars       Int      @default(3)
  description String?  @db.Text
  imageUrl    String?  @db.Text
  amenities   String?  @db.Text // JSON string
  managerId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  manager      User?              @relation("HotelManager", fields: [managerId], references: [id])
  rooms        Room[]
  reservations HotelReservation[]

  @@map("hotels")
}

model Room {
  id            String   @id @default(cuid())
  hotelId       String
  roomNumber    String
  type          RoomType @default(DOUBLE)
  pricePerNight Decimal  @db.Decimal(10, 2)
  capacity      Int      @default(2)
  isAvailable   Boolean  @default(true)
  description   String?
  imageUrl      String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  hotel        Hotel              @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  reservations HotelReservation[]

  @@map("rooms")
}

// ========================
// RESERVATIONS
// ========================
model FlightReservation {
  id            String            @id @default(cuid())
  userId        String
  flightId      String
  seatsBooked   Int               @default(1)
  totalPrice    Decimal           @db.Decimal(10, 2)
  status        ReservationStatus @default(PENDING)
  paymentStatus PaymentStatus     @default(PENDING)
  seatClass     String            @default("ECONOMY")
  passengerInfo String?           @db.Text // JSON
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  flight  Flight   @relation(fields: [flightId], references: [id])
  payment Payment?

  @@map("flight_reservations")
}

model HotelReservation {
  id              String            @id @default(cuid())
  userId          String
  hotelId         String
  roomId          String
  checkIn         DateTime
  checkOut        DateTime
  totalPrice      Decimal           @db.Decimal(10, 2)
  status          ReservationStatus @default(PENDING)
  paymentStatus   PaymentStatus     @default(PENDING)
  guestCount      Int               @default(1)
  specialRequests String?           @db.Text
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  hotel   Hotel    @relation(fields: [hotelId], references: [id])
  room    Room     @relation(fields: [roomId], references: [id])
  payment Payment?

  @@map("hotel_reservations")
}

// ========================
// PAYMENT
// ========================
model Payment {
  id                  String        @id @default(cuid())
  amount              Decimal       @db.Decimal(10, 2)
  method              String        @default("CARD") // CARD, PAYPAL, etc.
  status              PaymentStatus @default(PENDING)
  transactionId       String?       @unique
  flightReservationId String?       @unique
  hotelReservationId  String?       @unique
  cardLast4           String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  flightReservation FlightReservation? @relation(fields: [flightReservationId], references: [id])
  hotelReservation  HotelReservation?  @relation(fields: [hotelReservationId], references: [id])

  @@map("payments")
}

// ========================
// REVIEW
// ========================
model Review {
  id        String   @id @default(cuid())
  userId    String
  flightId  String
  rating    Int // 1-5
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  flight Flight @relation(fields: [flightId], references: [id])

  @@unique([userId, flightId])
  @@map("reviews")
}

// ========================
// NOTIFICATION
// ========================
model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  type      String   @default("INFO") // INFO, SUCCESS, WARNING, ERROR
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
